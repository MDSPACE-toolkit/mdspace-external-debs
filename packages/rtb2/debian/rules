#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

ifeq ($(DEB_HOST_ARCH),amd64)
SAFE_ARCH_FLAGS = -march=x86-64 -mtune=generic
endif

export CFLAGS := $(shell dpkg-buildflags --get CFLAGS) $(SAFE_ARCH_FLAGS)
export CXXFLAGS := $(shell dpkg-buildflags --get CXXFLAGS) $(SAFE_ARCH_FLAGS)
export FFLAGS := $(shell dpkg-buildflags --get FFLAGS) $(SAFE_ARCH_FLAGS)
export FCFLAGS := $(shell dpkg-buildflags --get FCFLAGS) $(SAFE_ARCH_FLAGS)

%:
	dh $@

override_dh_auto_configure:
	cmake -S src -B src/build \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr

override_dh_auto_build:
	$(MAKE) -C src/build

override_dh_auto_install:
	install -d debian/rtb2/usr/bin
	install -m 0755 src/build/rtb2 debian/rtb2/usr/bin/rtb2
	install -m 0755 scripts/makebloc.pl debian/rtb2/usr/bin/makebloc.pl
